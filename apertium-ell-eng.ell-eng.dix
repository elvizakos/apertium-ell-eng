  <section id="main" type="standard">



    <!-- SECTION: Punctuation -->
    <e><re>[.\?;:!"…]+</re><p><l><s n="sent"/></l><r><s n="sent"/></r></p></e>
    <e><re>[0-9]+([.,][0-9]+)*[.,]*</re><p><l><s n="num"/></l><r><s n="num"/></r></p></e> 

	<!-- SECTION: Adverbs -->
	<e><p><l>ναί<s n="adv"/></l><r>yes<s n="adv"/></r></p></e>
	<e><p><l>όχι<s n="adv"/></l><r>no<s n="adv"/></r></p></e>
	<e><p><l>δεν<s n="adv"/></l><r>not<s n="adv"/></r></p></e>
	<e><p><l>δε<s n="adv"/></l><r>not<s n="adv"/></r></p></e>
        <e><p><l>γιατί<s n="adv"/></l><r>why<s n="adv"/></r></p></e>
        <e><p><l>που<s n="adv"/></l><r>where<s n="adv"/></r></p></e>
       <e><p><l>μαζί<s n="adv"/></l><r>together<s n="adv"/></r></p></e>
       <e><p><l>ποτέ<s n="adv"/></l><r>never<s n="adv"/></r></p></e>
       <e><p><l>μάλλον<s n="adv"/></l><r>maybe<s n="adv"/></r></p></e>
       <e><p><l>ακόμα<s n="adv"/></l><r>still<s n="adv"/></r></p></e>
