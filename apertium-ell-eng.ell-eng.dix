       <e><p><l>παντού<s n="adv"/></l><r>everywhere<s n="adv"/></r></p></e>


	<!-- SECTION: Particles -->
        <e><p><l>θα<s n="part"/></l><r>will<s n="vaux"/></r></p></e>


	<!-- SECTION: Determiners -->
	<e><p><l>ο<s n="det"/></l><r>the<s n="det"/></r></p></e>
	<e><p><l>ένας<s n="det"/></l><r>a<s n="det"/></r></p></e>

	<!-- SECTION: Personal Pronouns -->
	<e><p><l>prpers<s n="prn"/></l><r>prpers<s n="prn"/></r></p></e>
