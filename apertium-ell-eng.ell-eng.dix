	<!-- SECTION: Conjuctions -->
        <e><p><l>και<s n="cnjcoo"/></l><r>and<s n="cnjcoo"/></r></p></e>
        <e r="LR"><p><l>κι<s n="cnjcoo"/></l><r>and<s n="cnjcoo"/></r></p></e>
        <e><p><l>ή<s n="cnjcoo"/></l><r>or<s n="cnjcoo"/></r></p></e>
        <e><p><l>είτε<s n="cnjcoo"/></l><r>either<s n="cnjcoo"/></r></p></e>
        <e><p><l>ούτε<s n="cnjcoo"/></l><r>nor<s n="cnjcoo"/></r></p></e>
        <e r="LR"><p><l>μήτε<s n="cnjcoo"/></l><r>nor<s n="cnjcoo"/></r></p></e>
        <e r="LR"><p><l>ουδέ<s n="cnjcoo"/></l><r>nor<s n="cnjcoo"/></r></p></e>
        <e r="LR"><p><l>μηδέ<s n="cnjcoo"/></l><r>nor<s n="cnjcoo"/></r></p></e>
        <e><p><l>αλλά<s n="cnjcoo"/></l><r>but<s n="cnjcoo"/></r></p></e>
        <e r="LR"><p><l>όμως<s n="cnjcoo"/></l><r>but<s n="cnjcoo"/></r></p></e>
        <e r="LR"><p><l>μα<s n="cnjcoo"/></l><r>but<s n="cnjcoo"/></r></p></e>


        <e><p><l>ότι<s n="cnjsub"/></l><r>that<s n="cnjsub"/></r></p></e>
